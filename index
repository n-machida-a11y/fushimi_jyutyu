  <?!= include('Scripts'); ?>
  <?!= include('FormBuilder'); ?>

  <script>
    window.onload = () => {
      myModalInstance = new bootstrap.Modal(document.getElementById('editModal'));
      
      let checkCount = 0;
      const checkAndRender = () => {
        if (typeof renderTable === 'function' && typeof openModal === 'function') {
          const p = JSON.parse(document.getElementById('server-payload').textContent);
          if (p.success) {
            ALL_ORDERS = p.orders; HEADERS = p.headers; OPTIONS = p.options; HOME_COLS = p.homeColumns; PDF_CONFIGS = p.pdfConfigs;
            renderTable();
            document.getElementById('loadingOverlay').classList.add('hidden');
          } else { searchServer(); }
        } else {
          checkCount++;
          if (checkCount > 50) { 
            document.getElementById('loadingOverlay').innerHTML = '<div class="text-danger fw-bold bg-white p-3 border rounded shadow">プログラムの読み込みに失敗しました。<br>FormBuilder.html 等の構文エラーが原因です。</div>';
            return;
          }
          setTimeout(checkAndRender, 100);
        }
      };
      checkAndRender();
    };

    function parse(h) {
      const m = { raw: h, label: h, group: '基本', sub: null, sub2: null, width: 'col-12', sync: null, rowNum: null, isFixed: h.includes('★') };
      if(!h || typeof h !== 'string') return m;
      let w = h.trim();
      const syncMatch = w.match(/@sync\((.+?)\)/);
      if(syncMatch) { m.sync = syncMatch[1].trim(); w = w.replace(syncMatch[0], ''); }
      
      const wMatch = w.match(/\[w(\d)\]/i);
      if(wMatch) { 
        const n = wMatch[1]; 
        m.width = n==='4' ? 'col-3' : n==='3' ? 'col-4' : n==='2' ? 'col-6' : 'col-12'; 
        w = w.replace(wMatch[0], ''); 
      }
      
      const rMatch = w.match(/#(\d+)/); if(rMatch) { m.rowNum = rMatch[1]; w = w.replace(rMatch[0], ''); }
      const halfMatch = w.match(/\[half\]/i);
      if(halfMatch) { m.isHalfBox = true; w = w.replace(halfMatch[0], ''); }

      const parts = w.replace(/★|\[addr\]|\[zip\]/g, '').split(/[|:]/).map(s=>s.trim()).filter(Boolean);
      if(parts.length >= 1) m.group = parts[0];
      if(parts.length >= 4) { m.sub = parts[1]; m.sub2 = parts[2]; m.label = parts[3]; }
      else if(parts.length === 3) { m.sub = parts[1]; m.label = parts[2]; }
      else if(parts.length === 2) { m.label = parts[1]; }
      return m;
    }
  </script>
</body>
</html>
